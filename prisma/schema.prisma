// KK-Kirppis data model.
// Listing is intentionally generic (category field) so non-videogame
// categories can be added later without a schema rewrite.

generator client {
  provider = "prisma-client-js"
}

// Prisma 7: connection URLs live in prisma.config.ts (migrations) and the
// PrismaClient driver adapter (runtime) — not here.
datasource db {
  provider = "postgresql"
}

model User {
  // We persist only the Slack user id; name / @handle / avatar are fetched
  // live from Slack (users.info) and cached, so identity is never stale and
  // no profile data is stored. See src/lib/slack-profile.ts.
  id        String   @id @default(cuid())
  slackId   String   @unique // Slack user id (the OIDC `sub` claim)
  listings  Listing[]
  createdAt DateTime @default(now())
}

model Listing {
  id          String        @id @default(cuid())
  title       String
  description String
  priceCents  Int // integer cents, never floats
  category    String        @default("videogame") // generic / future-proof
  platform    String? // e.g. PS5, Switch (videogame-specific, optional)
  status      ListingStatus @default(ACTIVE)
  images      ListingImage[]
  seller      User          @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  sellerId    String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status, category, createdAt])
  @@index([sellerId])
}

model ListingImage {
  id        String  @id @default(cuid())
  url       String // Supabase Storage object path/URL
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String
  sortOrder Int     @default(0)

  @@index([listingId])
}

enum ListingStatus {
  ACTIVE
  SOLD
}
