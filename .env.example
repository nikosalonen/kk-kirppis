# ---- Database (Supabase Postgres) ----
# Pooled connection (pgbouncer, port 6543) used by the app at runtime.
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) used by `prisma migrate`.
DIRECT_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ---- Auth.js ----
# Generate with: npx auth secret   (or: openssl rand -base64 33)
AUTH_SECRET="replace-me-with-a-long-random-secret"
# In production set this to your canonical URL, e.g. https://kk-kirppis.vercel.app
# AUTH_URL="http://localhost:3000"

# ---- Slack "Sign in with Slack" app ----
# From your Slack app's OAuth & Permissions / Basic Information page.
AUTH_SLACK_ID="your-slack-client-id"
AUTH_SLACK_SECRET="your-slack-client-secret"
# Koodiklinikka workspace team id (looks like T0XXXXXXX). Only members of this
# workspace are allowed to sign in (verified against the Slack `team_id` claim).
KOODIKLINIKKA_SLACK_TEAM_ID="T00000000"

# ---- Supabase Storage (listing images) ----
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT.supabase.co"
# Service-role key: SERVER-ONLY. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
# Public bucket that stores listing images.
SUPABASE_STORAGE_BUCKET="listing-images"

# ---- RAWG (game metadata autofill) ----
# Free API key from https://rawg.io/apidocs
RAWG_API_KEY="your-rawg-api-key"

# ---- Slack channel announcements (optional) ----
# Bot User OAuth Token (xoxb-...) with chat:write. Leave empty to disable.
SLACK_BOT_TOKEN=""
# Channel id (C0...) to post new-listing announcements to.
SLACK_ANNOUNCE_CHANNEL_ID=""
